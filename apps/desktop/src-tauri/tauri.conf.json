{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Secret Hub",
  "version": "0.1.0",
  "identifier": "com.secret-hub.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Secret Hub",
        "width": 1160,
        "height": 760,
        "minWidth": 940,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
